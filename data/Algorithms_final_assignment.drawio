<mxfile host="app.diagrams.net">
  <diagram name="Pagina-1" id="nem2JZRFQCzcXqe3Xp9Q">
    <mxGraphModel dx="5150" dy="2810" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    direction TB\n\n    %% Central Application Classes\n    class Processing_Main {\n        +Room room\n        +Couch couch\n        +Television television\n        +Hand hand\n        +Lamp lamp\n        +Ball ball\n        +hairSystem hs\n        +Glass glass\n        +Flock flock\n        +Sky sky\n        +Painting painting\n        +Watermanagement water\n        +setup() void\n        +draw() void\n        +mouseDragged() void\n        +mouseReleased() void\n        +mousePressed() void\n        +keyPressed() void\n    }\n\n    class Room {\n        -PImage pot\n        -PImage plant\n        +display() void\n    }\n\n    class Couch {\n        -PImage sieb\n        -PImage cloth\n        +display() void\n    }\n\n    class Sky {\n        +display() void\n    }\n\n    class Lamp {\n        +display() void\n    }\n\n    %% Interactive &amp; Physics Entities\n    class Hand {\n        -PImage hand\n        -Ball ball\n        -PVector mousePos\n        -PVector position\n        -PVector Dragline\n        -boolean dragged\n        -PVector basePos\n        +display() void\n        +reset() void\n        +mouseReleasedEvent() void\n        +mouseDraggedEvent(PVector mouse) void\n    }\n\n    class Ball {\n        -PImage ball\n        +PVector position\n        +PVector velocity\n        +PVector acceleration\n        -PVector startpos\n        +float airtime\n        +boolean thrown\n        -boolean outside\n        -boolean hidden\n        +update(boolean isBroken) void\n        +display(boolean isBroken) void\n        +isOutOfScreen() boolean\n        +reset(PVector position) void\n        +setPosition(PVector position) void\n        +setVelocity(PVector velocity) void\n        +setAcceleration(PVector acceleration) void\n        +resetsize() void\n        +collidedog() void\n    }\n\n    class Glass {\n        -Ball ball\n        -int hitcount\n        -boolean isinside\n        +display() void\n        +render(PVector ballpos) void\n        +isHit(PVector ballpos) boolean\n        +collide(Ball ball) void\n        +isBroken() boolean\n    }\n\n    %% Subsystems and Particle Systems\n    class Television {\n        -float t\n        -boolean isOn\n        +display() void\n        +render() void\n        +click(int mx, int my) void\n    }\n\n    class Painting {\n        -float x\n        -float y\n        -float w\n        -float h\n        -float[] xCoords\n        -int totalLines\n        +display() void\n    }\n\n    class hairSystem {\n        -ArrayList~hair~ hairs\n        +makeHair(PVector pos) void\n        +updateHair() void\n    }\n\n    class hair {\n        -PVector position\n        -PVector velocity\n        -float lifespan\n        -float angle\n        +run() void\n        +update() void\n        +display() void\n        +isDead() boolean\n    }\n\n    class Flock {\n        -ArrayList~Bird~ birds\n        +run() void\n        +addBird(Bird b) void\n    }\n\n    class Bird {\n        -PVector position\n        -PVector velocity\n        -PVector acceleration\n        -float r\n        -float maxforce\n        -float maxspeed\n        -PImage bird\n        +run(ArrayList~Bird~ birds) void\n        +applyForce(PVector force) void\n        +flock(ArrayList~Bird~ birds) void\n        +update() void\n        +seek(PVector target) PVector\n        +render() void\n        +borders() void\n        +separate(ArrayList~Bird~ birds) PVector\n        +align(ArrayList~Bird~ birds) PVector\n        +cohesion(ArrayList~Bird~ birds) PVector\n    }\n\n    class Watermanagement {\n        -float mass\n        -float springConstant\n        -float damping\n        -system[] watersystems\n        +run() void\n        +click(int watermx, int watermy) void\n    }\n\n    class WaterSystem_Node {\n        -float mass\n        -float force\n        -float damping\n        -float velocity\n        -float acceleration\n        -float displacement\n        -float springConstant\n        -PVector position\n        +update() void\n        +calculateNeighbourForce(float distance) void\n    }\n\n    %% Relationships and Dependencies\n    Processing_Main --&gt; Room : manages\n    Processing_Main --&gt; Couch : manages\n    Processing_Main --&gt; Sky : manages\n    Processing_Main --&gt; Lamp : manages\n    Processing_Main --&gt; Painting : manages\n    Processing_Main --&gt; Television : manages\n    Processing_Main --&gt; Glass : manages\n    Processing_Main --&gt; Hand : manages\n    Processing_Main --&gt; Ball : manages\n    Processing_Main --&gt; hairSystem : manages\n    Processing_Main --&gt; Flock : manages\n    Processing_Main --&gt; Watermanagement : manages\n\n    Hand --&gt; Ball : manipulates / launches\n    Glass ..&gt; Ball : checks collision &amp; breaks\n    hairSystem *-- hair : contains multiple\n    Flock *-- Bird : contains multiple (Boids)\n    Watermanagement *-- WaterSystem_Node : links wave components&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="Cu2OgbEbHrIZwduNEzuT-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
